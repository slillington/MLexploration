# Copy this file to .env and fill in your values.
# .env is gitignored and will not be committed.

# NCBI E-utilities API key (optional, increases rate limit from 3 to 10 req/s)
# Get one at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=

# Email for NCBI API requests (required by NCBI terms of use)
NCBI_EMAIL=your_email@example.com

# Semantic Scholar API key (optional, raises rate limit)
# Request one at: https://www.semanticscholar.org/product/api#api-key
S2_API_KEY=
